{
  "name": "@ogds/elements",
  "version": "1.0.0-alpha.8",
  "type": "module",
  "customElements": "custom-elements.json",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-government-design-system/ogds-elements.git"
  },
  "files": [
    ".storybook",
    "storybook",
    "build",
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/components/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*": "./dist/components/*.js",
    "./components/frameworks/react/*": "./dist/components/frameworks/react/*.js",
    "./src/components/*": "./src/components/*/index.js",
    "./core/*": "./src/core/*",
    "./styles/*": "./build/*",
    "./components/ogds-accordion/styles": "./src/components/ogds-accordion/ogds-accordion.css"
  },
  "scripts": {
    "build": "tsc -p ./config/tsconfig.json && vite build --config ./config/vite.config.ts && npm run manifest:build",
    "build:watch": "vite build --config ./config/vite.config.ts --watch",
    "dev": "vite --config ./config/vite.config.ts",
    "eslint": "eslint .",
    "fix-permissions": "sudo chown -R $(id -u):$(id -g) .",
    "pages": "npm run storybook:build && cp -r storybook-static _site",
    "playwright:install": "playwright install --with-deps",
    "playwright:test": "playwright test --config=./config/playwright.config.ts",
    "playwright:update-screenshots": "playwright test --config=./config/playwright.config.ts --update-snapshots",
    "prepare": "husky",
    "prettier:js": "prettier --check '**/*.{cjs,css,js,json,jsx,mjs,ts,tsx}' --config ./config/.prettierrc",
    "prettier:js:fix": "prettier --write '**/*.{cjs,css,js,json,jsx,mjs,ts,tsx}' --config ./config/.prettierrc",
    "prettier:md": "prettier --check '**/*.{md,mdx}' --config ./config/.prettierrc",
    "prettier:md:fix": "prettier --write '**/*.{md,mdx}' --config ./config/.prettierrc",
    "prettier:github": "prettier --check '.github' --config ./config/.prettierrc",
    "prettier:github:fix": "prettier --write '.github' --config ./config/.prettierrc",
    "start": "run-pty % npm run storybook % npm run manifest:watch",
    "storybook:build": "storybook build",
    "storybook": "storybook dev -p 8008",
    "prestorybook:serve": "npm run storybook:build --quiet",
    "storybook:serve": "node ./internals/scripts/serve-storybook.js",
    "stylelint": "stylelint './src/components/**/*.{css,css.js,css.ts}' --config=./config/stylelint.config.mjs",
    "stylelint:fix": "stylelint './src/components/**/*.{css,css.js,css.ts}' --fix --config=./config/stylelint.config.mjs",
    "manifest:build": "cem analyze --config ./config/custom-elements-manifest.config.js",
    "manifest:watch": "cem analyze --config ./config/custom-elements-manifest.config.js --watch --dev",
    "release": "npm run build && changeset publish",
    "test": "vitest --config ./config/vitest.config.js",
    "test:ci": "vitest run --config ./config/vitest.config.js",
    "test:storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run storybook:serve\" \"wait-on tcp:127.0.0.1:3000 && npx test-storybook --url http://localhost:3000\"",
    "vite:preview": "vite preview --config ./config/vite.config.ts"
  },
  "dependencies": {
    "@ogds/tokens": "^1.0.0-alpha.2",
    "@uswds/uswds": "^3.13.0",
    "lit": "^3.3.3",
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@storybook/web-components-vite": "^10.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/serve-static": "^2.2.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vitest/ui": "^4.1.9",
    "@wc-toolkit/storybook-helpers": "^10.5.1",
    "axe-playwright": "^2.2.2",
    "browserslist": "^4.28.4",
    "concurrently": "^10.0.3",
    "custom-element-jsx-integration": "^1.6.0",
    "custom-element-react-wrappers": "^1.7.3",
    "custom-element-solidjs-integration": "^1.9.0",
    "custom-element-svelte-integration": "^1.2.0",
    "custom-element-vuejs-integration": "^1.4.0",
    "custom-elements-manifest": "^2.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "10.4.6",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "pkg-pr-new": "^0.0.75",
    "prettier": "^3.9.4",
    "run-pty": "^6.0.2",
    "serve-static": "^2.2.1",
    "shadow-dom-testing-library": "^1.14.0",
    "storybook": "^10.0.7",
    "storybook-addon-tag-badges": "^3.1.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vite-plugin-bundlesize": "^0.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lit-css": "^3.0.0",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.10",
    "web-vitals": "^5.3.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  },
  "allowScripts": {
    "esbuild@0.25.9": true,
    "esbuild@0.27.3": true,
    "@parcel/watcher@2.5.1": true,
    "@swc/core@1.13.5": true,
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true,
    "unrs-resolver@1.11.1": true,
    "rs-module-lexer@2.6.0": true
  }
}
