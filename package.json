{
  "name": "@uswds/elements",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "customElements": "custom-elements.json",
  "files": [
    ".storybook",
    "storybook",
    "scripts",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./components/*": "./dist/components/*.js",
    "./src/components/*": "./src/components/*/index.js",
    "./core/*": "./src/core/*"
  },
  "scripts": {
    "build": "tsc && vite build && npm run manifest:build",
    "build:tokens": "style-dictionary build --config ./style-dictionary.config.js",
    "build:watch": "vite build --watch",
    "dev": "vite",
    "prettier:js": "npx prettier --check '**/*.{cjs,css,js,json,jsx,mjs,ts,tsx}'",
    "prettier:js:fix": "npx prettier --write '**/*.{cjs,css,js,json,jsx,mjs,ts,tsx}'",
    "prettier:md": "npx prettier --check '**/*.{md,mdx}'",
    "prettier:md:fix": "npx prettier --write '**/*.{md,mdx}'",
    "start": "npm run storybook & npm run manifest:watch",
    "storybook:build": "storybook build",
    "storybook": "storybook dev -p 8008",
    "manifest:build": "npx cem analyze --litelement",
    "manifest:watch": "npx cem analyze --litelement --watch --dev",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run storybook:build --quiet && npx http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && npx test-storybook\"",
    "vite:preview": "vite preview",
    "pages": "npm run storybook:build && cp -r storybook-static _site"
  },
  "dependencies": {
    "@uswds/uswds": "^3.11.0",
    "lit": "^3.2.1",
    "sass": "^1.84.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.0.1",
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@eslint/css": "^0.9.0",
    "@storybook/addon-a11y": "^9.0.18",
    "@storybook/addon-docs": "^9.0.18",
    "@storybook/addon-links": "^9.0.18",
    "@storybook/test-runner": "^0.23.0",
    "@storybook/web-components-vite": "^9.0.18",
    "@vitest/eslint-plugin": "^1.3.4",
    "@vitest/ui": "^3.2.4",
    "axe-playwright": "^2.1.0",
    "concurrently": "^8.2.2",
    "custom-elements-manifest": "^2.1.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-storybook": "9.0.18",
    "http-server": "^14.1.1",
    "jsdom": "^24.1.1",
    "prettier": "^3.6.2",
    "shadow-dom-testing-library": "^1.11.3",
    "storybook": "^9.0.18",
    "style-dictionary": "^5.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.34.6"
  }
}
