{
  "name": "@uswds/elements",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "customElements": "custom-elements.json",
  "files": [
    ".storybook",
    "storybook",
    "internals/scripts",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./components/*": "./dist/components/*.js",
    "./src/components/*": "./src/components/*/index.js",
    "./core/*": "./src/core/*"
  },
  "scripts": {
    "build": "tsc && vite build && npm run manifest:build",
    "build:tokens": "style-dictionary build --config ./style-dictionary.config.js",
    "build:watch": "vite build --watch",
    "dev": "vite",
    "fix-permissions": "sudo chown -R $(id -u):$(id -g) .",
    "prettier:js": "npx prettier --check '**/*.{cjs,css,js,json,jsx,mjs,ts,tsx}'",
    "prettier:js:fix": "npx prettier --write '**/*.{cjs,css,js,json,jsx,mjs,ts,tsx}'",
    "prettier:md": "npx prettier --check '**/*.{md,mdx}'",
    "prettier:md:fix": "npx prettier --write '**/*.{md,mdx}'",
    "start": "npm run storybook & npm run manifest:watch",
    "storybook:build": "storybook build",
    "storybook": "storybook dev -p 8008",
    "prestorybook:serve": "npm run storybook:build --quiet",
    "storybook:serve": "node internals/scripts/serve-storybook.js",
    "stylelint": "stylelint './src/components/**/*.{css,css.js,css.ts}'",
    "stylelint:fix": "stylelint './src/components/**/*.{css,css.js,css.ts}' --fix",
    "manifest:build": "npx cem analyze",
    "manifest:watch": "npx cem analyze --watch --dev",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npm run storybook:serve\" \"wait-on tcp:127.0.0.1:3000 && npx test-storybook --url http://localhost:3000\"",
    "vite:preview": "vite preview",
    "pages": "npm run storybook:build && cp -r storybook-static _site",
    "prepare": "husky"
  },
  "dependencies": {
    "@uswds/uswds": "^3.11.0",
    "lit": "^3.2.1",
    "sass": "^1.84.0"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@eslint/css": "^0.9.0",
    "@playwright/test": "^1.55.1",
    "@storybook/addon-a11y": "^9.0.18",
    "@storybook/addon-docs": "^9.0.18",
    "@storybook/addon-links": "^9.0.18",
    "@storybook/test-runner": "^0.23.0",
    "@storybook/web-components-vite": "^9.0.18",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/serve-static": "^1.15.8",
    "@vitest/eslint-plugin": "^1.3.4",
    "@vitest/ui": "^3.2.4",
    "@wc-toolkit/storybook-helpers": "^9.0.1",
    "axe-playwright": "^2.1.0",
    "browserslist": "^4.26.3",
    "concurrently": "^8.2.2",
    "custom-elements-manifest": "^2.1.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-storybook": "9.0.18",
    "express": "^5.1.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.1",
    "lightningcss": "^1.30.2",
    "prettier": "^3.6.2",
    "serve-static": "^2.2.0",
    "shadow-dom-testing-library": "^1.11.3",
    "storybook": "^9.0.18",
    "storybook-addon-tag-badges": "^2.0.3",
    "style-dictionary": "^5.0.1",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-order": "^7.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.5",
    "vite-plugin-bundlesize": "^0.3.0",
    "vite-plugin-lit-css": "^2.2.1",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0",
    "web-vitals": "^5.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.34.6"
  }
}
